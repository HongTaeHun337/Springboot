spring:
  application:
    name: jpa
    
  # JDBC 설  
  datasource:
     driver-class-name: oracle.jdbc.OracleDriver
     username: springboot
     url: jdbc:oracle:thin:@localhost:1521/XEPDB1
     password: java1234
     
  # JPA 설정
  jpa:
    database: oracle
    hibernate:
      ddl-auto: none
      naming:
        physical-strategy: org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
    show-sql: true
    properties:
      hibernates:
        format-sql: true
        highlight_sql: true
        
        
logging:
  level:
    org:
      hibernate:
        sql: debug
        orm:
          jdbc:
            bind: trace
              
