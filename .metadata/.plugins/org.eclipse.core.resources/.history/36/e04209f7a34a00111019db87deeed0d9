	@PostMapping("/m3ok")
	public String m3ok(Model model, ItemDto dto) {
		
		//CR[U]D
		//- 레코드 수정하기
		//1. 엔티티 직접 생성 > 값을 수정 > 수정하기
		//2. 검색 > 엔티티 반환 > 값을 수정 > 수정하기
		
		Optional<Item> item = itemRepository.findById(dto.getSeq());
		
		Item result = item.get();
		
		//*** JPA에 대하는 개발자 태도 > 무게감!!
		//- dto.setName("이름") > 이후 발생하는 일들 > 다양
		//- entity.setName("이름") > 반드시 DB에 반영
		
		//result.setName("수정")
		
		//안전 장치
		result.update(dto.getName(), dto.getPrice(), dto.getColor(), dto.getQty(), dto.getDescription()); //엔티티 > 수정할 데이터 반영
		
		itemRepository.save(result);
				
		return "result";
	}
	
