<!DOCTYPE html>
<html lang="ko" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Thymeleaf</title>
    <link rel="stylesheet" href="http://bit.ly/3WJ5ilK" />
</head>
<body>
    <!-- m9.html -->
    <h1>제어 속성</h1>
    
    <!-- 
    <c:if test="${seq > 0}">
        <div>${seq}는 양수입니다.</div>
    </c:if>
    -->
    
    <div th:if="false"><span th:text=${seq}></span>는 양수입니다.</div>
    
    <div th:if="${seq > 0}"><span th:text=${seq}></span>는 양수입니다.</div>
    <div th:if="${seq > 0}" th:text="${seq} + '는 양수입니다.'"></div>
    <div th:if="${seq > 0}" th:text="|${seq}는 양수입니다.|"></div>
    <div th:if="${seq > 0}">[[${seq}]]는 양수입니다.</div>
    
    <hr>
    
    <div th:if="${seq > 0}">양수입니다.</div>
    <div th:if="${seq < 0}">음수입니다.</div>
    <div th:if="${seq == 0}">0 입니다.</div>
    
    <hr>
    
    <div th:if="${seq > 0}">양수입니다.</div>
    <div th:unless="${seq > 0}">양수가 아닙니다.</div>
    
    <hr>
    
    <div th:switch="${mode}">
        <div th:case="add">추가하기</div>
        <div th:case="edit">수정하기</div>
        <div th:case="del">삭제하기</div>
        <div th:case="*">기타</div>
    </div>
    
    <hr>
    
    <!-- 
    <ul>
        <c:forEach items="${items}" var="dto">
        <li>${name}</li>
        </c:forEach>
    </ul>
     -->
     
    <ul>
        <li th:each="name : ${names}" th:text="${name}"></li>
    </ul>
    
    <hr>
    
    <ul>
        <li th:each="dto : ${list}"
            th:text="${dto.name} + '-' + ${dto.age}"></li>
    </ul>
    
    <hr>
    
    <div th:each="num : ${#numbers.sequence(1, 10)}" 
        th:text="${num}"></div>
        
    <hr>
    
    <div th:if="${seq}">10은 양수입니다.</div>
    
    
</body>
</html>













